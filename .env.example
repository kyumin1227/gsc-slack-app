# Required for all modes
SLACK_BOT_TOKEN=xoxb-

# Required for socket mode
SLACK_APP_TOKEN=xapp-
SLACK_SOCKET_MODE=true

# Required for HTTP mode
SLACK_SIGNING_SECRET=your-signing-secret

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=gsc_slack_app
DB_SYNCHRONIZE=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Google Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=example@example.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY----------END PRIVATE KEY-----\n

# Security
ENCRYPTION_SECRET=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# Google Calendar Watch
GOOGLE_WEBHOOK_URL=https://example.com

# CloudFlare (개발 환경의 경우)
CLOUDFLARE_TUNNEL_TOKEN=